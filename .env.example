# Local dev uses the Vite proxy at /chainview-api.
# GitHub Pages must use an HTTPS API proxy URL here because browsers block
# direct calls from HTTPS pages to http://chainview.kro.kr:8080.
#
# Example:
# VITE_CHAINVIEW_API_BASE_URL=https://chainview-api-proxy.<account>.workers.dev
VITE_CHAINVIEW_API_BASE_URL=/chainview-api

VITE_CHAINVIEW_EMPLOYEE_NO=8913812
